{
  "name": "@rozenite/mcp-server",
  "version": "1.2.0",
  "description": "MCP server for Rozenite - exposes React Native tools to LLMs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rozenite-mcp": "./bin/rozenite-mcp.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "react-native",
    "devtools",
    "mcp",
    "model-context-protocol",
    "llm"
  ],
  "homepage": "https://github.com/callstackincubator/rozenite#readme",
  "bugs": {
    "url": "https://github.com/callstackincubator/rozenite/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/callstackincubator/rozenite.git"
  },
  "author": "Szymon Chmal <szymon.chmal@callstack.com>",
  "license": "MIT",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "clean": "rm -rf dist"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/ws": "^8.5.13"
  },
  "engines": {
    "node": ">=20"
  }
}
